# Copy to leadhunter/.env and fill in secrets

# Anthropic (email drafting)
ANTHROPIC_API_KEY=

# Optional: Apollo enrichment
APOLLO_API_KEY=

# Gmail API — place credentials/credentials.json under backend/credentials/
GMAIL_CREDENTIALS_PATH=credentials/credentials.json
GMAIL_TOKEN_PATH=credentials/token.json
GMAIL_POLL_INTERVAL=60

# SQLite — default is ../data/leadhunter.db relative to backend/
# DATABASE_URL=sqlite+aiosqlite:///./data/leadhunter.db

SCRAPE_RATE_LIMIT=4.0
LOG_LEVEL=INFO
